"""
Configuration Template for GateGuard
Copy to .env file and customize for your environment
"""

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
DATABASE_PATH=college_gate.db
DATABASE_BACKUP_DIR=backups/

# Camera Settings
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
DETECTION_INTERVAL=1.5

# ANPR Detection
PLATE_CONFIDENCE_THRESHOLD=0.25
PLATE_COOLDOWN_SECONDS=8
PLATE_DETECTION_TIMEOUT=5

# OCR Engine
OCR_LANGUAGE=en
OCR_GPU=False
OCR_MODEL_PATH=~/.EasyOCR/model/

# Admin Credentials (CHANGE IN PRODUCTION!)
ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
ADMIN_STUDENT_ID=ADMIN001

# Session Configuration
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=1
WORKER_CLASS=eventlet
DEBUG=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/gateguard.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# WebSocket Configuration
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ALLOWED_ORIGINS=*
SOCKETIO_PING_TIMEOUT=60
SOCKETIO_PING_INTERVAL=25

# Email Notifications (Optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL=

# Feature Flags
ENABLE_EMAIL_ALERTS=False
ENABLE_SMS_ALERTS=False
ENABLE_WEBHOOK=False
WEBHOOK_URL=

# Performance Tuning
MAX_LOG_ROWS=10000
PAGINATION_SIZE=20
CACHE_TIMEOUT=300
THREAD_POOL_SIZE=4

# Security
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,bmp
MAX_IMAGE_SIZE=10485760
PASSWORD_MIN_LENGTH=6
SESSION_TIMEOUT=3600

# Indian Plate Recognition Settings
INDIAN_PLATE_ENABLED=True
PLATE_REGION=INDIA
VALIDATE_PLATE_FORMAT=True

# Timezone
TIMEZONE=Asia/Kolkata
DATE_FORMAT=%d-%m-%Y
TIME_FORMAT=%H:%M:%S
DATETIME_FORMAT=%d-%m-%Y %H:%M:%S
